        "acme/wp-plugin": "*",
        "acme/views": "*",
        "acme/my-plugin": "*",
        "acme/payments": "*",
        "composer/installers": "^2.0"
    },
    "repositories": [
        {"type": "path", "url": "packages/wp", "options": {"symlink": false}},
        {"type": "path", "url": "packages/drupal", "options": {"symlink": false}},
