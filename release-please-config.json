{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "separator": "-",
  "include-component-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "plugins": [
    "cargo-workspace"
  ],
  "packages": {
    "crates/composer-installers": {},
    "crates/composer-autoload": {},
    "crates/composer-patches": {
      "release-as": "0.1.0"
    },
    "crates/composer-manifest": {
      "release-as": "0.1.0"
    },
    "crates/composer-install": {}
  }
}
